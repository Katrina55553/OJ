# OJ 后端环境变量配置
# 复制此文件为 .env 并填入真实值
# .env 文件已被 .gitignore 排除，不会提交到仓库

# === 数据库 ===
DB_URL=jdbc:mysql://localhost:3306/yuoj
DB_USERNAME=root
DB_PASSWORD=your_password_here

# === Redis ===
REDIS_HOST=localhost
REDIS_PASSWORD=your_redis_password

# === RabbitMQ ===
RABBITMQ_HOST=localhost
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# === JWT 认证 ===
# 密钥长度需 >= 256 位（32 字符），生产环境务必更换
JWT_SECRET=your-jwt-secret-key-at-least-32-chars

# === JDoodle 代码执行 API ===
# 注册地址: https://www.jdoodle.com/compiler-api/
JDOODLE_CLIENT_ID=your_client_id
JDOODLE_CLIENT_SECRET=your_client_secret

# === AI 聊天（Ollama） ===
# Docker 部署时使用 http://ollama:11434（容器内访问）
# 本地开发时使用 http://localhost:11434
OLLAMA_BASE_URL=http://ollama:11434
# 模型名称，启动后需手动拉取: docker exec -it oj-ollama ollama pull deepseek-r1:7b
OLLAMA_MODEL=deepseek-r1:7b

# === Redis（可选，默认未启用） ===
REDIS_HOST=localhost
REDIS_PASSWORD=your_redis_password

# === Elasticsearch（可选） ===
ES_URL=http://localhost:9200
ES_USERNAME=root
ES_PASSWORD=your_es_password

# === 腾讯云 COS（可选，文件上传功能） ===
COS_ACCESS_KEY=your_access_key
COS_SECRET_KEY=your_secret_key
COS_REGION=your_region
COS_BUCKET=your_bucket

# === 微信开放平台（可选，微信登录功能） ===
WX_MP_APP_ID=your_app_id
WX_MP_SECRET=your_secret
WX_MP_TOKEN=your_token
WX_MP_AES_KEY=your_aes_key
WX_OPEN_APP_ID=your_open_app_id
WX_OPEN_APP_SECRET=your_open_app_secret
